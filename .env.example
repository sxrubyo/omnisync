# Omni runtime
OMNI_HOME=/opt/omni-core
OMNI_CONFIG_DIR=/opt/omni-core/config
OMNI_STATE_DIR=/opt/omni-core/data
OMNI_BACKUP_DIR=/opt/omni-core/backups
OMNI_BUNDLE_DIR=/opt/omni-core/backups/host-bundles
OMNI_LOG_DIR=/opt/omni-core/logs
OMNI_MANIFEST_FILE=/opt/omni-core/config/system_manifest.json

# Notifications
OMNI_TELEGRAM_TOKEN=
SANTIAGO_CHAT_ID=

# Encrypted secrets pack
OMNI_SECRET_PASSPHRASE=

# CLI toggles
OMNI_DEBUG=false
OMNI_VERBOSE=false
